# RDF Turtle representation of the DDI-CDI to DDSC mapping configuration
# Description : DDI-CDI to CDIF Profile Data Description
# Version     : 1

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sssom: <https://w3id.org/sssom/> .
@prefix uml: <http://www.omg.org/spec/UML/2.5.1/> .
@prefix transform: <http://w3id.org/ucmis/vocab/transform#> .
@prefix cdi: <http://ddialliance.org/Specification/DDI-CDI/1.0/RDF/> .
@prefix ddsc: <http://w3id.org/cdif/ddsc/1.0/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# ── Transformation activity ──────────────────────────────────────────────────

cdi:DDICDILibrary
    a uml:Model ;
    rdfs:label "DDI-CDI" ;
    dcterms:identifier "DDICDILibrary" ;
    rdfs:isDefinedBy <http://ddialliance.org/Specification/DDI-CDI/1.0/XMI/> .

ddsc:DDSC
    a uml:Model ;
    rdfs:label "UML Model for the Cross-Domain Interoperability Framework (CDIF)" ;
    dcterms:identifier "DDSC" ;
    rdfs:comment "Many important research questions demand a multi-disciplinary approach in which data and resources are used across domain and infrastructure boundaries. In such scenarios, domain-specific community standards fall short of the requirements for FAIR exchange of the critical metadata and other information needed. The Cross-Domain Interoperability Framework (CDIF) is designed to support FAIR implementation for these projects by establishing a ‘lingua franca’ for this information, based on existing standards and technology to support interoperability, in both human- and machine-actionable fashion. CDIF is a set of implementation recommendations, based on profiles of common, domain-neutral metadata standards which are aligned to work together to support core functions required by FAIR." ;
    rdfs:isDefinedBy <http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/> .

[] a prov:Activity ;
    rdfs:label "DDI-CDI to CDIF Profile Data Description" ;
    dcterms:hasVersion "1" ;
    prov:used cdi:DDICDILibrary ;
    prov:generated ddsc:DDSC .

# ── Packages ─────────────────────────────────────────────────────────────────

ddsc:Classes
    a uml:Package ;
    rdfs:label "Classes" ;
    rdfs:comment "This package contains the definitions of the classes in the DDSC profile with all their relationships and attributes." ;
    transform:parentPackage ddsc:DDSC .

# ── Class mappings ───────────────────────────────────────────────────────────

ddsc:ClassMapping_DataStore
    a transform:ClassMapping ;
    transform:mappingType "map" ;
    transform:sourceClass cdi:DataStore ;
    transform:targetClass ddsc:DataStore ;
    transform:targetPackage ddsc:Classes ;
    transform:hasAttribute
    [
        a uml:Attribute ;
        rdfs:label "name" ;
        transform:multiplicityLower "1" ;
        transform:multiplicityUpper "1"
    ] ;
    transform:hasMapping ddsc:SSSOMMapping_DataStore_1 .

ddsc:SSSOMMapping_DataStore_1
    a sssom:Mapping ;
    sssom:subject_label "DDI-CDI DataStore" ;
    sssom:object_label "CDIF DDSC DataStore" ;
    sssom:predicate_id "skos:narrowMatch" ;
    sssom:predicate_label "Object class has less attributes." ;
    sssom:confidence "1.0"^^xsd:decimal ;
    rdfs:comment "Object class has less attributes." .

ddsc:ClassMapping_LogicalRecord
    a transform:ClassMapping ;
    transform:mappingType "map" ;
    transform:sourceClass cdi:LogicalRecord ;
    transform:targetClass ddsc:LogicalRecord ;
    transform:targetPackage ddsc:Classes .

ddsc:ClassMapping_WideDataSet
    a transform:ClassMapping ;
    transform:mappingType "merge" ;
    transform:sourceClass cdi:WideDataSet, cdi:PhysicalDataSet ;
    transform:targetClass ddsc:WideDataSet ;
    transform:targetPackage ddsc:Classes ;
    transform:definitionFrom cdi:WideDataSet ;
    transform:hasAttribute
    [
        a uml:Attribute ;
        rdfs:label "name" ;
        transform:multiplicityLower "1" ;
        transform:multiplicityUpper "1" ;
        transform:fromSourceClass cdi:PhysicalDataSet
    ] ;
    transform:hasAttribute
    [
        a uml:Attribute ;
        rdfs:label "physicalFileName" ;
        transform:multiplicityLower "1" ;
        transform:multiplicityUpper "1" ;
        transform:fromSourceClass cdi:PhysicalDataSet
    ] ;
    transform:hasMapping ddsc:SSSOMMapping_WideDataSet_1 .

ddsc:SSSOMMapping_WideDataSet_1
    a sssom:Mapping ;
    sssom:subject_label "Merge of DDI-CDI WideDataSet and PhysicalDataSet" ;
    sssom:object_label "CDIF DDSC WideDataSet" ;
    sssom:predicate_id "skos:relatedMatch" ;
    sssom:predicate_label "Object class takes definition from WideDataSet and some attributes from PhysicalDataSet." ;
    sssom:confidence "1.0"^^xsd:decimal ;
    rdfs:comment "Object class takes definition from WideDataSet and some attributes from PhysicalDataSet." .

